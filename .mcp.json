{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "/workspace/node/bin/npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--no-sandbox"
      ],
      "env": {
        "PATH": "/workspace/node/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "PLAYWRIGHT_BROWSERS_PATH": "/workspace/ms-playwright"
      }
    }
  }
}